# Swift build output (regenerated by `swift build`)
.build/

# Assembled / installed app bundles & disk images (built by make_app.sh / build_and_notarize.sh)
*.app
*.dmg

# macOS
.DS_Store

# Python bytecode (the sidecar/ tree is kept as the e5-quality baseline; its bytecode is regenerable)
__pycache__/
*.pyc

# Build-time model-conversion venv (recreate per the header of tools/convert_e5.py)
tools/.venv/

# Code-signing material — never commit. Certs live in the Keychain; back up a .p12 OFF the repo.
*.cer
*.p12

# Build output (signed app + notarized dmg)
build/

# Sample PDFs — kept local only (copyright/confidential); never commit.
PDF Samples/
*.pdf
